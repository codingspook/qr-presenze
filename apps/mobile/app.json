{
  "expo": {
    "name": "Attendance QR",
    "slug": "attendance-qr",
    "scheme": "attendanceqr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Consenti a $(PRODUCT_NAME) di usare la fotocamera per scansionare i QR delle presenze.",
          "barcodeScannerEnabled": true
        }
      ]
    ]
  }
}
